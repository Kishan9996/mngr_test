# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Set to "grok" or "claude". Only the keys for the active provider are required.
LLM_PROVIDER=grok

# xAI / Grok (used when LLM_PROVIDER=grok)
GROK_API_KEY=xai-...
GROK_MODEL=grok-3

# Anthropic / Claude (used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Google Calendar OAuth ────────────────────────────────────────────────────
# Download credentials.json from Google Cloud Console (OAuth 2.0 Web client)
# and fill in the values below, OR point to the file directly.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Redirect URI must be registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8000/api/calendar/auth/google/callback

# ─── Outlook / Microsoft Graph ────────────────────────────────────────────────
# Register an app in Azure Portal → App registrations
OUTLOOK_CLIENT_ID=your-azure-app-client-id
OUTLOOK_CLIENT_SECRET=your-azure-app-client-secret
OUTLOOK_TENANT_ID=common
OUTLOOK_REDIRECT_URI=http://localhost:8000/api/calendar/auth/outlook/callback

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_DAYS=30

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./chatbot.db

# ─── Cache ────────────────────────────────────────────────────────────────────
# Leave empty to use the in-memory fallback (fine for local dev without Docker)
REDIS_URL=redis://localhost:6379

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
# URL of the Next.js frontend (used for OAuth redirects after token exchange)
FRONTEND_URL=http://localhost:3000
# Default scheduling window (days ahead to search for slots)
SCHEDULING_LOOKAHEAD_DAYS=7
# Working hours defaults (24h format, user can override per session)
DEFAULT_WORK_START=09:00
DEFAULT_WORK_END=17:00
DEFAULT_SLOT_DURATION_MINUTES=60
DEFAULT_TIMEZONE=UTC
